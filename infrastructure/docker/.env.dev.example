# ============================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.dev and fill with actual values
# WARNING: Never commit .env.dev to git!

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
DEBUG_MODE=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=telegram_vpn_dev
DB_USER=vpn_dev_user
DB_PASSWORD=dev_password_change_me_123!

# Connection pool
DB_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=30000

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password_456!
REDIS_TIMEOUT=2000

# ============================================
# SECURITY & SECRETS
# ============================================
# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=YOUR_DEV_JWT_SECRET_CHANGE_ME_LONG_STRING_HERE

# JWT Expiration (milliseconds)
JWT_EXPIRATION=86400000        # 24 hours
JWT_REFRESH_EXPIRATION=604800000  # 7 days

# Internal Service Secret
INTERNAL_SECRET=Dev_Internal_Secret_2024_Change_Me!

# ============================================
# SERVICE PORTS
# ============================================
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
VPN_CONFIG_SERVICE_PORT=8082
SERVER_MANAGEMENT_SERVICE_PORT=8083
BILLING_SERVICE_PORT=8084

# ============================================
# SERVICE URLS (for inter-service communication)
# ============================================
USER_SERVICE_URL=http://user-service:8081
VPN_CONFIG_SERVICE_URL=http://vpn-config-service:8082
SERVER_MANAGEMENT_SERVICE_URL=http://server-management-service:8083
BILLING_SERVICE_URL=http://billing-service:8084

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=DEBUG
ENABLE_METRICS=true
ENABLE_PROMETHEUS=true

# ============================================
# MOCK CONFIGURATION (only for dev)
# ============================================
MOCK_SERVER_MANAGEMENT=true
MOCK_PAYMENT_PROVIDER=true

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PAYMENTS=false
ENABLE_REFERRALS=true

# ============================================
# ADMIN USERS (Telegram IDs)
# ============================================
ADMIN_USER_IDS=123456789,987654321
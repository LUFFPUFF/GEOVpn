# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# CRITICAL: Use strong passwords and rotate regularly!
# Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
DEBUG_MODE=false

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=${DB_HOST}  # From external secrets manager
DB_PORT=5432
DB_NAME=telegram_vpn_prod
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# Connection pool (increased for production)
DB_POOL_SIZE=20
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_TIMEOUT=2000

# ============================================
# SECURITY & SECRETS
# ============================================
# CRITICAL: Store these in secrets manager!
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRATION=3600000         # 1 hour (shorter for security)
JWT_REFRESH_EXPIRATION=604800000  # 7 days

INTERNAL_SECRET=${INTERNAL_SECRET}

# ============================================
# SERVICE PORTS (internal Docker network)
# ============================================
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
VPN_CONFIG_SERVICE_PORT=8082
SERVER_MANAGEMENT_SERVICE_PORT=8083
BILLING_SERVICE_PORT=8084

# ============================================
# SERVICE URLS
# ============================================
USER_SERVICE_URL=http://user-service:8081
VPN_CONFIG_SERVICE_URL=http://vpn-config-service:8082
SERVER_MANAGEMENT_SERVICE_URL=http://server-management-service:8083
BILLING_SERVICE_URL=http://billing-service:8084

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=${FRONTEND_URL}

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_PROMETHEUS=true

# Logging service URLs
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090

# ============================================
# EXTERNAL SERVICES
# ============================================
# Payment providers
YOOMONEY_SHOP_ID=${YOOMONEY_SHOP_ID}
YOOMONEY_SECRET_KEY=${YOOMONEY_SECRET_KEY}

# Telegram Bot
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
TELEGRAM_WEBHOOK_URL=${TELEGRAM_WEBHOOK_URL}

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PAYMENTS=true
ENABLE_REFERRALS=true

# ============================================
# ADMIN USERS
# ============================================
ADMIN_USER_IDS=${ADMIN_TELEGRAM_IDS}

# ============================================
# RESOURCE LIMITS
# ============================================
JAVA_MAX_MEMORY=512m
JAVA_MIN_MEMORY=256m

# ============================================
# BACKUP & RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=${BACKUP_S3_BUCKET}